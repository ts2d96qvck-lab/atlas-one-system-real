# Atlas One — Environment Variables
# Copy to `.env` at repository root for Docker Compose production.
# Copy relevant sections to `apps/server/.env` and `apps/web/.env.local` for local dev.

# =============================================================================
# CORE
# =============================================================================
NODE_ENV=development
# production | development

LOG_LEVEL=info
# debug | info | warn | error

# Public URL of the application (fixed domain — no trycloudflare)
APP_PUBLIC_URL=https://app.atlasone.app.br
WEBHOOK_PUBLIC_URL=https://app.atlasone.app.br

# =============================================================================
# API SERVER
# =============================================================================
PORT=4000
HOST=0.0.0.0

DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://atlas:CHANGE_ME@localhost:5432/atlas_one

REDIS_URL=redis://localhost:6379

JWT_SECRET=CHANGE_ME_MIN_32_RANDOM_CHARACTERS_REQUIRED

# Comma-separated origins allowed in production (include your fixed domain)
CORS_ORIGINS=https://app.atlasone.app.br,https://*.atlasone.app.br

# Platform operators (comma-separated emails)
PLATFORM_ADMIN_EMAILS=admin@atlasone.com.br

# One-time bootstrap token (disable public bootstrap in production)
SETUP_TOKEN=
ALLOW_PUBLIC_BOOTSTRAP=false

# SSO / OIDC (optional — see SSO_PLAN.md)
# Callback must hit the API: /auth/oidc/callback (nginx proxies /auth in production)
OIDC_REDIRECT_URI=https://app.atlasone.app.br/auth/oidc/callback
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
MICROSOFT_OIDC_CLIENT_ID=
MICROSOFT_OIDC_CLIENT_SECRET=
MICROSOFT_OIDC_TENANT=common
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# =============================================================================
# WEB (Next.js)
# =============================================================================
# In production behind reverse proxy, browser uses same origin — these are fallbacks for SSR/build.
NEXT_PUBLIC_API_URL=https://app.atlasone.app.br
NEXT_PUBLIC_WS_URL=https://app.atlasone.app.br

# =============================================================================
# WHATSAPP — Evolution API (SMB default)
# =============================================================================
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=CHANGE_ME
EVOLUTION_DEFAULT_INSTANCE=Atlas one
WHATSAPP_DEFAULT_PROVIDER=evolution

# Meta WhatsApp Cloud API (optional — enterprise)
# META_WHATSAPP_ACCESS_TOKEN=
# META_WHATSAPP_PHONE_NUMBER_ID=
# META_WHATSAPP_BUSINESS_ACCOUNT_ID=
# META_WHATSAPP_API_VERSION=v22.0
# META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# META_WHATSAPP_APP_SECRET=
ATLAS_ALLOW_SIMULATED_WHATSAPP=false

# =============================================================================
# WEBHOOKS & PAYMENTS
# =============================================================================
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
PAYMENTS_WEBHOOK_SECRET=CHANGE_ME_PAYMENTS_SECRET

# ASAAS_WEBHOOK_TOKEN=  # Token configurado no painel Asaas (header asaas-access-token)
PAYMENT_PROVIDER=manual
ASAAS_API_KEY=
ASAAS_ENV=sandbox

# =============================================================================
# SMS / 2FA
# =============================================================================
# console | whatsapp | twilio | webhook
SMS_PROVIDER=console
SMS_FROM=AtlasOne
ATLAS_ALLOW_LOCAL_SMS=true

# WhatsApp via Evolution (dev/staging)
EVOLUTION_DEFAULT_INSTANCE_SMS=Atlas one

# Twilio (production recommended)
SMS_TWILIO_SID=
SMS_TWILIO_TOKEN=
SMS_TWILIO_FROM=

# Custom webhook provider
SMS_WEBHOOK_URL=
SMS_API_TOKEN=

# =============================================================================
# DOCKER COMPOSE PRODUCTION (optional overrides)
# =============================================================================
POSTGRES_USER=atlas
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=atlas_one

# =============================================================================
# AUDIO TRANSCRIPTION (Whisper-compatible APIs)
# =============================================================================
# OpenAI Whisper (paid) or Groq Whisper (free tier available)
OPENAI_API_KEY=
GROQ_API_KEY=
# openai | groq — auto-detects from keys if omitted
TRANSCRIPTION_PROVIDER=
TRANSCRIPTION_MODEL=whisper-1

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# ATLAS_ENTERPRISE_MODE=false
# Use `pnpm dev` for development — never `pnpm dev` in production.
