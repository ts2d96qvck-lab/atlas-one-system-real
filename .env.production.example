# Atlas One — Production Environment
# Copy to `.env` on the server before `docker compose -f docker-compose.prod.yml up -d`
#
# Quick generate (replace domain):
#   node scripts/generate-staging-env.mjs app.atlasone.app.br

NODE_ENV=production
LOG_LEVEL=info

# === Domínio de produção ===
APP_PUBLIC_URL=https://app.atlasone.app.br
# Public URL (browser/docs). Evolution delivery uses EVOLUTION_WEBHOOK_BASE_URL until TLS/443 is live.
WEBHOOK_PUBLIC_URL=https://app.atlasone.app.br
# Evolution container reaches nginx on the Docker network (HTTP port 80). Preferred until SSL is enabled.
EVOLUTION_WEBHOOK_BASE_URL=http://nginx
# Alternative internal URL (bypass nginx): http://atlas-server:4000
# Set true only after HTTPS/443 is active on the VPS.
WEBHOOK_USE_HTTPS=false

PORT=4000
HOST=0.0.0.0

POSTGRES_USER=atlas
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=atlas_one
DATABASE_URL=postgresql://atlas:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/atlas_one

REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_STRONG_REDIS_PASSWORD@redis:6379

JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_SECRET
WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET
PAYMENTS_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET
SETUP_TOKEN=REPLACE_WITH_SETUP_TOKEN_FOR_FIRST_TENANT

EVOLUTION_URL=http://evolution-api:8080
EVOLUTION_API_KEY=REPLACE_WITH_EVOLUTION_KEY
EVOLUTION_DEFAULT_INSTANCE=Atlas one

CORS_ORIGINS=https://app.atlasone.app.br,http://app.atlasone.app.br
PLATFORM_ADMIN_EMAILS=admin@atlasone.com.br
ALLOW_PUBLIC_BOOTSTRAP=false
ATLAS_ALLOW_LOCAL_SMS=false
# MVP: never block login for suspicious IP/UA (audit only). Default true unless explicitly false.
DISABLE_SUSPICIOUS_2FA=true
ATLAS_ALLOW_SIMULATED_WHATSAPP=false
ATLAS_ENTERPRISE_MODE=true

PAYMENT_PROVIDER=asaas
ASAAS_API_KEY=
ASAAS_ENV=sandbox

WHATSAPP_DEFAULT_PROVIDER=evolution
EVOLUTION_PUBLIC_URL=https://app.atlasone.app.br

SMS_PROVIDER=webhook
SMS_WEBHOOK_URL=
SMS_API_TOKEN=
ASAAS_WEBHOOK_TOKEN=REPLACE_WITH_SAME_AS_PAYMENTS_WEBHOOK_OR_DEDICATED

NEXT_PUBLIC_API_URL=https://app.atlasone.app.br
NEXT_PUBLIC_WS_URL=https://app.atlasone.app.br
