{
  "name": "@atlas-one/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json --noEmit && node ../../scripts/bundle-server.js",
    "start": "node dist/server.mjs",
    "start:dev": "tsx src/server.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:disable-menu-bot": "tsx prisma/disable-menu-bot.ts"
  },
  "dependencies": {
    "@atlas-one/lib": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.1",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.3",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "qrcode": "^1.5.4",
    "prisma": "^6.9.0",
    "socket.io": "^4.8.1",
    "zod": "^3.25.51"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.29",
    "@types/qrcode": "^1.5.6",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
